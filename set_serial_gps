#!/bin/sh
/usr/bin/systemctl stop gpsd.service gpsd.socket
sleep 1

/usr/bin/ubxtool -v 1  -s 9600 -S 115200 -f /dev/ttyAMA0
/usr/bin/ubxtool -v 1  -s 115200 -f /dev/ttyAMA0 -d GLONASS
/usr/bin/ubxtool -v 1  -s 115200 -f /dev/ttyAMA0 -e GALILEO
/usr/bin/ubxtool -v 1  -s 115200 -f /dev/ttyAMA0 -p SAVE

sleep 1

/usr/bin/systemctl start gpsd.service gpsd.socket

